### =============================================================================
# COMPLETE WORKFLOW TEST
### =============================================================================

### WORKFLOW: Complete Trip Lifecycle
# 1. Fleet Manager creates vehicle and driver
# 2. Dispatcher creates trip (DRAFT)
# 3. Dispatcher dispatches trip (DISPATCHED) - vehicle becomes ON_TRIP, driver becomes ON_TRIP
# 4. Add fuel log for the trip
# 5. Add expense (toll, other) for the trip
# 6. Dispatcher completes trip (COMPLETED) - vehicle becomes AVAILABLE, driver becomes AVAILABLE
# 7. Check analytics

### 1. CREATE VEHICLE FOR WORKFLOW
# @name wf_vehicle
POST {{baseUrl}}/api/vehicles
Authorization: Bearer {{fleetManagerToken}}
Content-Type: {{contentType}}

{
  "regNo": "WF01AB1234",
  "name": "Workflow Vehicle",
  "type": "LCV",
  "capacity": 2000,
  "acqCost": 1000000
}

@wf_vehicleId = {{wf_vehicle.response.body._id}}

### 2. CREATE DRIVER FOR WORKFLOW
# @name wf_driver
POST {{baseUrl}}/api/drivers
Authorization: Bearer {{fleetManagerToken}}
Content-Type: {{contentType}}

{
  "name": "Workflow Driver",
  "licenseNo": "WFDL123456",
  "category": "LMV",
  "expiry": "2029-12-31",
  "contact": "9876501234"
}

@wf_driverId = {{wf_driver.response.body._id}}

### 3. CREATE TRIP (DRAFT)
# @name wf_trip
POST {{baseUrl}}/api/trips
Authorization: Bearer {{dispatcherToken}}
Content-Type: {{contentType}}

{
  "tripNo": "WF-TRP-001",
  "source": "Ahmedabad",
  "destination": "Surat",
  "vehicle": "{{wf_vehicleId}}",
  "driver": "{{wf_driverId}}",
  "cargoWeight": 1500,
  "plannedDistance": 265
}

@wf_tripId = {{wf_trip.response.body._id}}

### 4. DISPATCH TRIP
POST {{baseUrl}}/api/trips/{{wf_tripId}}/dispatch
Authorization: Bearer {{dispatcherToken}}
Content-Type: {{contentType}}

{}

### 5. ADD FUEL LOG FOR TRIP
POST {{baseUrl}}/api/expenses/fuel
Authorization: Bearer {{analystToken}}
Content-Type: {{contentType}}

{
  "vehicle": "{{wf_vehicleId}}",
  "liters": 80,
  "fuelCost": 8000,
  "date": "2024-01-15T06:00:00Z"
}

### 6. ADD EXPENSE FOR TRIP
POST {{baseUrl}}/api/expenses
Authorization: Bearer {{analystToken}}
Content-Type: {{contentType}}

{
  "trip": "{{wf_tripId}}",
  "vehicle": "{{wf_vehicleId}}",
  "toll": 1500,
  "other": 300
}

### 7. COMPLETE TRIP
POST {{baseUrl}}/api/trips/{{wf_tripId}}/complete
Authorization: Bearer {{dispatcherToken}}
Content-Type: {{contentType}}

{}

